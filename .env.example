# ─── Flow AI Engine — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in all values marked REQUIRED.
# .env is gitignored — never commit secrets.

# ── Shared Flow AI Supabase ──────────────────────────────────────────────────
# The shared Supabase project that holds the `clients` table.
# Used to load per-client config at runtime.
SHARED_SUPABASE_URL=https://your-shared-project.supabase.co          # REQUIRED
SHARED_SUPABASE_SERVICE_KEY=your-shared-service-role-key             # REQUIRED

# ── LLM ─────────────────────────────────────────────────────────────────────
# Production (Railway): LLM_PROVIDER=anthropic
# Local eval (Copilot subscription): LLM_PROVIDER=github_models + GITHUB_TOKEN
LLM_PROVIDER=anthropic                                               # REQUIRED (anthropic | github_models)
ANTHROPIC_API_KEY=sk-ant-...                                         # REQUIRED when LLM_PROVIDER=anthropic

# Optional model override — leave blank to use provider default.
# Anthropic default: claude-sonnet-4-6
# GitHub Models default: claude-sonnet-4-6-20250219
# LLM_MODEL_OVERRIDE=

# ── LLM Fallback (OpenAI GPT-4o-mini) ───────────────────────────────────────
# Activated per-request when Anthropic API is unreachable.
# Set LLM_FALLBACK_ENABLED=false to disable during testing.
OPENAI_API_KEY=sk-...                                                # REQUIRED for fallback
OPENAI_FALLBACK_MODEL=gpt-4o-mini                                    # optional, default gpt-4o-mini
LLM_FALLBACK_ENABLED=true                                            # optional, default true

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                                                       # optional, default INFO

# ── Per-client env vars ──────────────────────────────────────────────────────
# Pattern: {CLIENT_ID_UPPER}_{VAR}
# CLIENT_ID_UPPER = client_id.upper().replace("-", "_")
# Example for client "hey-aircon" → prefix HEY_AIRCON_

# HeyAircon
HEY_AIRCON_META_WHATSAPP_TOKEN=your-meta-token                       # REQUIRED
HEY_AIRCON_SUPABASE_URL=https://heyaircon.supabase.co               # REQUIRED
HEY_AIRCON_SUPABASE_SERVICE_KEY=your-heyaircon-service-key          # REQUIRED
HEY_AIRCON_GOOGLE_CALENDAR_CREDS={"type":"service_account",...}     # REQUIRED (JSON string)

# ── Railway ──────────────────────────────────────────────────────────────────
# PORT is injected automatically by Railway — do not set manually.
# PORT=8000
